generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  schemas         = ["moneyjournal"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["moneyjournal"]
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())

  @@schema("moneyjournal")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model landingMessage {
  id         BigInt   @id @default(autoincrement())
  name       String?
  email      String?
  message    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  ip_address String?

  @@schema("moneyjournal")
}

model signals {
  id         BigInt   @id @default(autoincrement())
  room_id    String
  sender     String
  signal     Json
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@schema("moneyjournal")
}

model Account {
  userId            String  @map("user_id")
  provider          String
  providerAccountId String  @map("provider_account_id")
  type              String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("moneyjournal")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("moneyjournal")
}

model User {
  id            String          @id @default(cuid())
  email         String?         @unique
  emailVerified DateTime?       @map("email_verified")
  name          String?
  image         String?
  password      String?
  accounts      Account[]
  paymentSource paymentSource[]
  sessions      Session[]
  transaction   transaction[]
  wallet        wallet[]
  category      category[]

  @@map("users")
  @@schema("moneyjournal")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("moneyjournal")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model wishes {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?
  name       String?  @unique
  message    String?
  is_locked  Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("moneyjournal")
}

model category {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  name       String
  icon       String?
  color      String?
  created_at DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamp(6)
  deleted_at DateTime?     @db.Timestamp(6)

  users       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transaction transaction[]

  @@map("category")
  @@schema("moneyjournal")
}

model paymentSource {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  name        String
  icon        String?
  created_at  DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamp(6)
  deleted_at  DateTime?     @db.Timestamp(6)
  default     Boolean       @default(false)

  users       User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction transaction[]
  wallets     WalletPaymentSource[]

  @@map("payment_source")
  @@schema("moneyjournal")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transaction {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String?
  title             String
  amount            Decimal         @db.Decimal
  notes             String?
  date              DateTime?       @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at        DateTime?       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamp(6)
  type              TransactionType
  deleted_at        DateTime?       @db.Timestamp(6)
  transferPairId    String?
  payment_source_id String?         @map("payment_source_id") @db.Uuid
  category_id       String?         @map("category_id") @db.Uuid
  wallet_id         String?         @map("wallet_id") @db.Uuid

  paymentSource paymentSource? @relation(fields: [payment_source_id], references: [id])
  category      category?      @relation(fields: [category_id], references: [id])
  wallet        wallet?        @relation(fields: [wallet_id], references: [id])
  users         User?          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("moneyjournal")
}

model limitn8n {
  limit Decimal @db.Decimal
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  @@schema("moneyjournal")
}

model wallet {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  title      String
  amount     Decimal        @db.Decimal
  created_at DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamp(6)
  deleted_at DateTime?      @db.Timestamp(6)
  icon       String?

  users           User                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_sources WalletPaymentSource[]
  transaction     transaction[]

  @@schema("moneyjournal")
}

model WalletPaymentSource {
  wallet_id         String  @db.Uuid
  payment_source_id String  @db.Uuid

  wallet         wallet         @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  payment_source paymentSource  @relation(fields: [payment_source_id], references: [id], onDelete: Cascade)

  @@id([wallet_id, payment_source_id])
  @@map("wallet_payment_source")
  @@schema("moneyjournal")
}

enum TransactionType {
  income
  outcome

  @@schema("moneyjournal")
}
